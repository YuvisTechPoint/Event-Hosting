APP_NAME="Event Hosting"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_LOG_QUERIES=false
APP_URL=http://localhost:1234
APP_PORT=1234
APP_FRONTEND_URL=http://localhost:5678
APP_CDN_URL=http://localhost:1234/storage
APP_SAAS_MODE_ENABLED=false
APP_SAAS_STRIPE_APPLICATION_FEE_PERCENT=1.5
APP_SAAS_STRIPE_APPLICATION_FEE_FIXED=0
APP_HOMEPAGE_VIEWS_UPDATE_BATCH_SIZE=8
APP_HOMEPAGE_TICKET_QUANTITIES_CACHE_TTL=30
APP_PUBLIC_EVENT_CACHE_TTL=300
APP_ANALYTICS_CACHE_TTL=300
APP_DISABLE_REGISTRATION=false
APP_STRIPE_CONNECT_ACCOUNT_TYPE=express
APP_PLATFORM_SUPPORT_EMAIL=support@your-website.com
APP_ALLOWED_INTERNAL_WEBHOOK_HOSTS=

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CORS_ALLOWED_ORIGINS=http://localhost:5678,http://localhost:1234

# Security hardening (see config/security.php)
# SECURITY_LOGIN_MAX_ATTEMPTS=5
# SECURITY_VIRUS_SCAN_ENABLED=false
# SECURITY_CLAMAV_HOST=clamav
# SECURITY_CLAMAV_PORT=3310

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker dev: DB_HOST=pgsql | Native Windows: DB_HOST=127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=backend
DB_USERNAME=username
DB_PASSWORD=password

# Real-time broadcasting (Section 6.1). Use `log` locally; `pusher` with Soketi for websockets.
BROADCAST_DRIVER=log
# BROADCAST_DRIVER=pusher
# PUSHER_APP_ID=hievents
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=mt1
# PUSHER_HOST=127.0.0.1
# PUSHER_PORT=6001
# PUSHER_SCHEME=http
CACHE_DRIVER=file
# Docker dev (with MinIO): s3-public / s3-private
# Native Windows / production without S3: public / local
FILESYSTEM_PUBLIC_DISK=public
FILESYSTEM_PRIVATE_DISK=local
QUEUE_CONNECTION=sync
WEBHOOK_QUEUE_NAME=webhook-queue
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Docker production: set PUSHER_HOST=soketi (see docker/production/.env.example)

# Docker dev: REDIS_HOST=redis | Native Windows: 127.0.0.1 (optional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Native Windows: use log driver. Docker dev: smtp + mailpit.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 / MinIO (only when FILESYSTEM_*_DISK=s3-public/s3-private)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_PUBLIC_BUCKET=hievents-public
AWS_PRIVATE_BUCKET=hievents-private
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Generate with: php artisan key:generate --show
# JWT: openssl rand -base64 64
JWT_SECRET=
JWT_ALGO=HS256

# Only required for SAAS mode and if you're charging fees
# OPEN_EXCHANGE_RATES_APP_ID=

# --- Production overrides (set APP_ENV=production, APP_DEBUG=false) ---
# QUEUE_CONNECTION=redis
# CACHE_DRIVER=redis
# SESSION_DRIVER=redis
# CORS_ALLOWED_ORIGINS=https://your-domain.com
# SECURITY_VIRUS_SCAN_ENABLED=true
# SECURITY_CLAMAV_HOST=clamav
# MAIL_MAILER=smtp
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
