# Event Hosting — production Docker environment
# Copy to .env and fill in all required values before deploying.
# NEVER commit the .env file.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Event Hosting"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_FRONTEND_URL=https://your-domain.com
APP_CDN_URL=https://your-domain.com/storage
APP_DISABLE_REGISTRATION=false
APP_SAAS_MODE_ENABLED=false
APP_SAAS_STRIPE_APPLICATION_FEE_PERCENT=0
APP_SAAS_STRIPE_APPLICATION_FEE_FIXED=0
APP_PLATFORM_SUPPORT_EMAIL=support@your-domain.com
APP_PUBLIC_EVENT_CACHE_TTL=300
APP_HOMEPAGE_TICKET_QUANTITIES_CACHE_TTL=30
APP_ANALYTICS_CACHE_TTL=300
APP_API_RATE_LIMIT_PER_MINUTE=180

# Generate with: php artisan key:generate --show
# JWT: openssl rand -base64 64
JWT_SECRET=
JWT_ALGO=HS256

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Set to false after initial deploy if you manage migrations manually
RUN_MIGRATIONS=true

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=hievents
POSTGRES_USER=hievents
POSTGRES_PASSWORD=

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
WEBHOOK_QUEUE_NAME=webhook-queue

# -----------------------------------------------------------------------------
# Mail (configure your SMTP provider)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# File storage (local disks — mount storage_data volume)
# For S3/MinIO, set FILESYSTEM_* to s3-public/s3-private and configure AWS_* vars.
# -----------------------------------------------------------------------------
FILESYSTEM_PUBLIC_DISK=public
FILESYSTEM_PRIVATE_DISK=local

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_PUBLIC_BUCKET=
# AWS_PRIVATE_BUCKET=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=true

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Broadcasting (Soketi / self-hosted Pusher)
# Generate app credentials with: openssl rand -hex 16
# -----------------------------------------------------------------------------
BROADCAST_DRIVER=pusher
PUSHER_APP_ID=hievents
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http

# -----------------------------------------------------------------------------
# Frontend (VITE_* — baked at build time AND passed at runtime for SSR)
# Replace your-domain.com with your public URL (include /api suffix for client).
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_FRONTEND_URL=https://your-domain.com
VITE_API_URL_CLIENT=https://your-domain.com/api
VITE_API_URL_SERVER=http://nginx/api
VITE_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLIC_KEY}

# Optional: expose Soketi to browser clients through nginx
VITE_PUSHER_APP_KEY=${PUSHER_APP_KEY}
VITE_PUSHER_HOST=your-domain.com
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://your-domain.com

# -----------------------------------------------------------------------------
# Nginx (host ports)
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# TLS certificates (optional — mount into nginx at docker/production/nginx/ssl/)
# fullchain.pem, privkey.pem — then uncomment HTTPS block in nginx/conf.d/hievents.conf

# -----------------------------------------------------------------------------
# Soketi metrics (internal only — not exposed to the Internet)
# -----------------------------------------------------------------------------
SOKETI_METRICS_SERVER_PORT=9601
