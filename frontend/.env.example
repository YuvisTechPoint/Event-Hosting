# Frontend environment — copy to .env
#
# Native Windows dev (Vite proxy /api -> backend :1234):
VITE_API_URL_CLIENT=/api
VITE_API_URL_SERVER=http://127.0.0.1:1234
VITE_FRONTEND_URL=http://localhost:5678
#
# Docker dev (via nginx :8443):
# VITE_API_URL_CLIENT=https://localhost:8443/api
# VITE_API_URL_SERVER=http://backend:80
# VITE_FRONTEND_URL=https://localhost:8443

VITE_STRIPE_PUBLISHABLE_KEY=
VITE_APP_NAME=Event Hosting

# Real-time (Soketi / Pusher-compatible). Leave VITE_PUSHER_APP_KEY empty to disable Echo.
# Match backend PUSHER_* credentials.
# VITE_PUSHER_APP_KEY=your-pusher-key
# VITE_PUSHER_APP_CLUSTER=mt1
# VITE_PUSHER_HOST=127.0.0.1
# VITE_PUSHER_PORT=6001
# VITE_PUSHER_SCHEME=http

# Production (replace with your public URL):
# VITE_API_URL_CLIENT=https://your-domain.com/api
# VITE_API_URL_SERVER=http://nginx/api
# VITE_FRONTEND_URL=https://your-domain.com
# VITE_PUSHER_HOST=your-domain.com
# VITE_PUSHER_PORT=443
# VITE_PUSHER_SCHEME=https
